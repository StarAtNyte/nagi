<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Nagi"
    Manufacturer="Nagi Contributors"
    Version="0.1.0"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Language="1033"
    Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Nagi is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="Nagi" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="StartMenuShortcuts" />
    </Feature>
  </Package>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="Nagi" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="NagiMenuFolder" Name="Nagi" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="NagiExe"
              Source="target\release\nagi.exe"
              KeyPath="yes" />
        <Environment Id="PathEntry"
                     Name="PATH"
                     Value="[INSTALLFOLDER]"
                     Permanent="no"
                     Part="last"
                     Action="set"
                     System="yes" />
      </Component>

      <Component Id="LibMpv" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <File Id="LibMpvDll"
              Source="wix\libmpv.dll"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="StartMenuShortcuts" Directory="NagiMenuFolder">
      <Component Id="StartMenuShortcut" Guid="D4E5F6A7-B8C9-0123-DEF0-234567890123">
        <Shortcut Id="NagiStartMenuShortcut"
                  Name="Nagi"
                  Description="Lightning-fast video wallpaper daemon"
                  Target="[INSTALLFOLDER]nagi.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="NagiMenuFolderRemove" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\Nagi"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
